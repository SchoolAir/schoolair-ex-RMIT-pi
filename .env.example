# Device credentials
AUTH_TOKEN=

# Central server URL
SERVER_URL=http://localhost:3000

# How often to send data to central server (seconds)
INGEST_INTERVAL=10

# Cooldown between alerts (hours)
ALERT_COOLDOWN=3

# Alert confidence (consecutive breaches to confirm alert)
ALERT_CONFIDENCE = 3

# Mock sensor (development script)
MOCK_SENSOR_SCRIPT=./scripts/mock-sensor.sh