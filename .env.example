# Device credentials — received from /aqc/register on first boot
AUTH_TOKEN=

# Central server URL
SERVER_URL=http://localhost:3000

# How often to check thresholds and send alerts (milliseconds)
ALERT_INTERVAL=5000           # 5 seconds

# How often to send data to central server (milliseconds)
INGEST_INTERVAL=5000          # 5 seconds

# How often to retry failed ingest queue entries (milliseconds)
QUEUE_FLUSH_INTERVAL=10000  # 30 minutes

# Cooldown between alerts (milliseconds)
ALERT_COOLDOWN=120000         # 2 minutes

# Mock sensor
MOCK_SENSOR_SCRIPT=./mock-sensor.sh