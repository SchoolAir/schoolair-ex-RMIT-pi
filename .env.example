# Device credentials — received from /aqc/register on first boot
DEVICE_ID=
AUTH_TOKEN=

# Central server URL
SERVER_URL=https://data.schoolair.org

# How often to send queued measurements to central server (milliseconds)
INGEST_INTERVAL=3600000   # 60 minutes

# How often to send a snapshot to central server (milliseconds)
SNAPSHOT_INTERVAL=300000  # 5 minutes