# Device credentials — written here by the registration wizard after first boot
AUTH_TOKEN=

# Central server base URL (no trailing slash, no path)
SERVER_URL=https://data.schoolair.org

# Ingest endpoint — overrides the default {SERVER_URL}/aqc/v1/ingest
INGEST_URL=https://data.schoolair.org/node/aqc/v1/ingest

# Secondary (new AWS) server — best-effort mirror of every successful drain.
# Failure here never affects the primary drain or local buffering.
# NEW_SERVER_URL=http://13.210.246.204:3000
# NEW_AUTH_TOKEN=

# Sensor script — defaults to ./read-sensor.sh (the sen6x bridge)
# Override with ./scripts/mock-sensor.sh for development
MOCK_SENSOR_SCRIPT=./read-sensor.sh

# Device nickname shown on the dashboard (defaults to hostname if unset)
# DEVICE_NICKNAME=classroom-3b

# Local server port
PORT=8080

# Alert settings
# A single reading breaching a threshold triggers a two-stage verification
# routine (T+10s, T+30s → T+1m, T+2m).  ALERT_NEAR_PCT defines how close to
# the threshold the verification averages must be to count as "near" — e.g. 10
# means within 10% of the threshold (PM2.5 threshold 25 → near means ≥ 22.5).
ALERT_NEAR_PCT=10
ALERT_COOLDOWN_HOURS=1
# In-memory alert buffer capacity. SQLite is only written when this is full
# AND the server is unreachable. With a 1h cooldown per metric, 50 slots covers
# days of outage before SQLite is touched.
ALERT_BUFFER_CAPACITY=50

# In-memory buffer capacity (readings).
# SQLite is only written when this is full AND the server is unreachable.
# 500 readings @ 5 min active interval ≈ 41 hours of school-hours data.
BUFFER_CAPACITY=500